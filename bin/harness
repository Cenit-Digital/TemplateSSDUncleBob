#!/usr/bin/env bash
# harness — Lanzador del motor agnóstico del arnés SSD Uncle Bob (POSIX).
# Ejecuta el motor con el directorio actual (donde vive harness.config.json).
#   bin/harness <init|test|mutate|verify|status|help> [args]
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
command -v node >/dev/null 2>&1 || { echo "[FAIL] node no está instalado (requerido por el arnés)"; exit 1; }
exec node "$SCRIPT_DIR/../.harness/harness.mjs" "$@"
