{
  "$schema": "./harness.schema.json",
  "project": "mi-proyecto",
  "language": "generic",
  "description": "Rellena este archivo con los comandos de TU stack. Es el único punto que hace al arnés dependiente del lenguaje. Ver docs/configuration.md y los ejemplos en examples/.",
  "commands": {
    "install": "",
    "lint": "",
    "test": "",
    "mutate": "",
    "build": ""
  },
  "paths": {
    "src": "src",
    "tests": "tests",
    "features": "features",
    "progress": "progress",
    "spec": "project-spec.md",
    "feature_list": "feature_list.json"
  },
  "mutation": {
    "threshold": 0.8,
    "targets": []
  },
  "rules": {
    "one_feature_at_a_time": true,
    "require_approved_spec_to_implement": true,
    "require_tests_to_close": true,
    "require_mutation_to_close": true
  }
}
